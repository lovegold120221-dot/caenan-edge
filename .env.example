# ── Vapi ──────────────────────────────────────────────────────────────────────
VAPI_PRIVATE_API_KEY=your-vapi-private-key
VAPI_API_KEY=your-vapi-private-key
ORBIT_SECRET=your-vapi-private-key
NEXT_PUBLIC_ORBIT_TOKEN=your-vapi-public-key
NEXT_PUBLIC_VAPI_ASSISTANT_IVAN_ID=your-caenan-assistant-id

# ── App ───────────────────────────────────────────────────────────────────────
# For Vercel: set to your deployment URL e.g. https://caenan-edge.vercel.app
# For local dev: http://localhost:3375
NEXT_PUBLIC_APP_URL=https://your-vercel-domain.vercel.app

# ── Supabase ──────────────────────────────────────────────────────────────────
# For Vercel: use your Supabase CLOUD project URL + keys
# For local dev: use http://127.0.0.1:54321 + local JWT keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-supabase-anon-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── ElevenLabs / TTS ─────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-key
TTS_PROVIDER_KEY=your-elevenlabs-key
ECHO_PROVIDER_KEY=your-elevenlabs-key
ECHO_PROVIDER_BASE_URL=https://api.elevenlabs.io/v1
ELEVENLABS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ECHO_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Phone ─────────────────────────────────────────────────────────────────────
PHONE_NUMBER_ID=your-vapi-phone-number-id

# ── Optional ─────────────────────────────────────────────────────────────────
